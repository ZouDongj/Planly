{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "planly",
  "version": "1.0.0",
  "identifier": "com.z7614.planly",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Planly",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "dragDropEnabled": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "startMenuFolder": "Planly"
      }
    }
  }
}
